# Anthropic — used only for the Tier 2 Haiku semantic classifier.
# The headless Claude Code CLI uses its own auth; this key is just for routing.
ANTHROPIC_API_KEY=sk-ant-...

# Model id for the Tier 2 router (cheap + fast classifier).
JARVIS_ROUTER_MODEL=claude-haiku-4-5-20251001

# Absolute path to the Obsidian vault root.
JARVIS_VAULT=../vault/Jarvis_Vault

# Hard timeout (ms) for any headless Claude Code / skill invocation.
JARVIS_SKILL_TIMEOUT_MS=60000

PORT=3000
